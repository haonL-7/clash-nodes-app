{
  "name": "clash-nodes-app",
  "version": "1.0.0",
  "description": "Free proxy subscription & node directory — Windows desktop app",
  "author": "haonl-7",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.clashnodes.app",
    "productName": "ClashNodes",
    "directories": {
      "output": "release"
    },
    "files": [
      "app/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "src/assets/icon.png"
    },
    "portable": {
      "artifactName": "ClashNodes.exe"
    }
  },
  "dependencies": {
    "electron": "^33.0.0"
  },
  "devDependencies": {
    "electron-builder": "^25.0.0"
  }
}
