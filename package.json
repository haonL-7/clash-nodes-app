{
  "name": "clash-nodes-app",
  "version": "1.0.0",
  "description": "Free proxy subscription & node directory — Windows desktop app",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.clash-nodes.app",
    "productName": "Clash Nodes",
    "directories": {
      "output": "release"
    },
    "files": [
      "app/**/*",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "language": "2052"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "node-fetch": "^2.7.0"
  }
}
